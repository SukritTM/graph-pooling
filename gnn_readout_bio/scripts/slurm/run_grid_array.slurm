#!/bin/bash
# Job array: one SLURM task per (dataset, model, readout, seed) combination.
# Each task requests a modest GPU — avoids hogging large resources.
#
# The combo list is generated by scripts/slurm/gen_combos.py.
# Submit with:
#   python scripts/slurm/gen_combos.py          # writes combos.txt
#   N=$(wc -l < combos.txt)
#   sbatch --array=1-$N scripts/slurm/run_grid_array.slurm
#
# Default grid: BBBP+BACE × GCN+GIN+GAT+SAGE × mean+sum+max+attn × seeds 0,1,2
# = 2 × 4 × 4 × 3 = 96 jobs

#SBATCH --job-name=gnn_grid
#SBATCH --partition=gpu-preempt
#SBATCH --gres=gpu:1
#SBATCH --mem=16G
#SBATCH --cpus-per-task=4
#SBATCH --time=4:00:00
#SBATCH --output=logs/grid_%A_%a.out
#SBATCH --error=logs/grid_%A_%a.err

mkdir -p logs

module load conda/latest
conda activate graph-pooling

cd /work/pi_annagreen_umass_edu/Isha/graph-pooling/gnn_readout_bio

# Read the line corresponding to this array task (1-indexed)
LINE=$(sed -n "${SLURM_ARRAY_TASK_ID}p" combos.txt)
DATASET=$(echo "$LINE" | cut -f1)
MODEL=$(echo   "$LINE" | cut -f2)
READOUT=$(echo "$LINE" | cut -f3)
SEED=$(echo    "$LINE" | cut -f4)

CONFIG="configs/${DATASET,,}.yaml"

echo "Task $SLURM_ARRAY_TASK_ID: $DATASET / $MODEL / $READOUT / seed $SEED"

python scripts/run_single.py \
    --config   "$CONFIG" \
    --model    "$MODEL" \
    --readout  "$READOUT" \
    --seed     "$SEED" \
    --output_dir results/
